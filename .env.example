# Example environment variables for Parallel Processing Project
# Copy this file to .env and adjust values as needed.

# URL where backend API is reachable (used by the Streamlit frontend)
BACKEND_URL=http://localhost:8000

# Optional: Streamlit server port (frontend) and host
# STREAMLIT_PORT=8501
# STREAMLIT_ADDRESS=0.0.0.0

# Optional: Uvicorn host/port for backend
# UVICORN_HOST=0.0.0.0
# UVICORN_PORT=8000
